{
  "name": "mcre-tools",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "run-p api:build api:watch dev:vite",
    "dev:vite": "vite",
    "test": "vitest",
    "test:unit": "npm run test:once",
    "test:once": "vitest run",
    "e2e": "playwright test",
    "test:e2e": "npm run e2e",
    "test:e2e:debug": "playwright test --config=playwright.debug.config.ts",
    "build": "run-p type-check build-only",
    "build-only": "vite-ssg build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lambda:test": "python3 -m unittest discover backend/lambda/tests",
    "cdk:test": "cd backend/cdk && HOME=/tmp/mcre-tools-cdk-home PATH=.venv/bin:$PATH python3 -m unittest discover -s tests",
    "cdk": "cd backend/cdk && PATH=.venv/bin:$PATH cdk",
    "cdk:synth:dev": "CDK_ENV=dev npm run cdk -- synth --all",
    "cdk:diff:dev": "CDK_ENV=dev npm run cdk -- diff --all",
    "cdk:deploy:dev": "CDK_ENV=dev npm run cdk -- deploy --all",
    "cdk:synth:prod": "CDK_ENV=prod npm run cdk -- synth --all",
    "cdk:diff:prod": "CDK_ENV=prod npm run cdk -- diff --all",
    "cdk:deploy:prod": "CDK_ENV=prod npm run cdk -- deploy --all",
    "api:build": "rm -rf ./tmp-apis && npx openapi2aspida -c=./aspida.config.cjs -i=./openapi.yaml -o=./tmp-apis/ && rsync -a --delete ./tmp-apis/ ./src/apis/ && rm -rf ./tmp-apis",
    "api:watch": "chokidar ./openapi.yaml -c \"npm run api:build\""
  },
  "dependencies": {
    "@aspida/fetch": "^1.14.0",
    "@mdi/js": "^7.4.47",
    "@unhead/vue": "^2.1.13",
    "aspida": "^1.14.0",
    "dayjs": "^1.11.20",
    "vue": "^3.5.33",
    "vue-i18n": "^11.4.0",
    "vue-router": "^5.0.6",
    "vuetify": "^4.0.6"
  },
  "devDependencies": {
    "@intlify/unplugin-vue-i18n": "^11.1.2",
    "@playwright/test": "^1.59.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "aws-cdk": "^2.1120.0",
    "chokidar-cli": "^3.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-vuetify": "^4.6.2",
    "eslint-plugin-vue": "^10.9.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^8.0.4",
    "openapi2aspida": "^0.24.0",
    "prettier": "^3.8.3",
    "sass-embedded": "^1.99.0",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.10",
    "vite-plugin-vuetify": "^2.1.3",
    "vite-ssg": "^28.3.0",
    "vite-ssg-sitemap": "^0.10.0",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.8",
    "yaml": "^2.8.4"
  },
  "overrides": {
    "form-data": "^4.0.5",
    "picomatch": "^4.0.4"
  }
}
